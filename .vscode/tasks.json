{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "dev: localhost (server + Vite)",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "windows": {
        "options": {
          "env": {
            "PATH": "${env:ProgramFiles}\\nodejs;${env:LOCALAPPDATA}\\Programs\\node;${env:PATH}"
          }
        }
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      },
      "runOptions": {
        "instanceLimit": 1
      }
    }
  ]
}
