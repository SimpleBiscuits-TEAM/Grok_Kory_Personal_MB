%%{init: {'theme': 'dark', 'themeVariables': {'primaryColor': '#dc2626', 'primaryTextColor': '#fff', 'primaryBorderColor': '#dc2626', 'lineColor': '#888', 'secondaryColor': '#1e293b', 'tertiaryColor': '#0f172a', 'fontSize': '14px'}}}%%
graph TB
    subgraph USER["🔧 USER / VEHICLE"]
        direction LR
        OBD["OBD-II Port"]
        CSV["CSV Log Files<br/>(HP Tuners / EFILive)"]
        PEAK["PEAK PCAN-USB<br/>Device"]
    end

    subgraph HARDWARE["⚡ HARDWARE BRIDGE LAYER"]
        direction TB
        ELM["ELM327 Adapter<br/>(WebSerial API)"]
        PCAN["PCAN Bridge<br/>(Python WebSocket)"]
        subgraph PROTOCOLS["Protocol Stack"]
            OBDP["OBD-II Protocol<br/>(Mode 01-0A)"]
            UDS["UDS Protocol<br/>(ISO 14229)"]
            RAW["Raw CAN<br/>(Bus Monitor)"]
        end
    end

    subgraph TRANSPORT["🔌 TRANSPORT LAYER"]
        direction TB
        OBDC["OBD Connection<br/>(obdConnection.ts)"]
        UDST["UDS Transport<br/>(udsTransport.ts)"]
    end

    subgraph DATA["📊 DATA LAYER"]
        direction TB
        subgraph PID_DB["PID Database (366 PIDs)"]
            STD["Standard OBD-II<br/>(Mode 01/02)"]
            GM_EXT["GM Extended<br/>(Mode 22 DIDs)"]
            FORD_EXT["Ford Extended<br/>(Mode 22 DIDs)"]
            BMW_EXT["BMW UDS<br/>(Extended DIDs)"]
            PS_EXT["Powersports<br/>(CAN-am/Polaris/<br/>Kawasaki/Sea-Doo)"]
        end
        subgraph UDS_DB["UDS Reference Library"]
            DID_TBL["DID Tables<br/>(50+ DIDs)"]
            SEC_ACC["Security Access<br/>(Seed/Key Algos)"]
            ROUTINE["Routine Controls<br/>(15+ Procedures)"]
            IO_CTL["IO Controls<br/>(Actuator Tests)"]
            NRC["NRC Codes<br/>(Error Decode)"]
        end
        subgraph MOD_DB["Module Database"]
            FORD_MOD["Ford Modules<br/>(48 ECUs)"]
            RAM_MOD["RAM Modules<br/>(21 ECUs)"]
            GM_MOD["GM Modules<br/>(11 ECUs)"]
        end
        VIN_DB["VIN Decoder<br/>(WMI Database)"]
        DTC_DB["DTC Database<br/>(P/C/B/U Codes)"]
    end

    subgraph ANALYSIS["🧠 AI ANALYSIS ENGINE"]
        direction TB
        PARSER["CSV Parser<br/>(HP Tuners / EFILive /<br/>Datalogger Format)"]
        DIAG["Diagnostics Engine<br/>(Pattern Detection)"]
        REASON["Reasoning Engine<br/>(AI Fault Analysis)"]
        HEALTH["Health Report<br/>(Scoring System)"]
        DRAG["Drag Analyzer<br/>(1/4 Mile Timeslips)"]
    end

    subgraph TOOLS["🛠️ ACTIVE TOOL MODULES"]
        direction TB
        LOGGER["Live Datalogger<br/>(Real-time Charting)"]
        ISPY["IntelliSpy<br/>(AI CAN Sniffer)"]
        CODING["Vehicle Coding<br/>(Fuel Tank / Tire Size)"]
        CANAM["CAN-am VIN Changer<br/>(DESS Key Learn)"]
        PROCS["Service Procedures<br/>(DPF Regen / TPMS /<br/>Injector Coding)"]
        DTC_RDR["DTC Reader<br/>(Read/Clear Codes)"]
        SCAN["Module Scanner<br/>(Full Bus Scan)"]
    end

    subgraph AI["🤖 ERIKA — AI ASSISTANT"]
        direction TB
        LLM["LLM Engine<br/>(Server-side)"]
        KB["Knowledge Base<br/>(erikaKnowledge.ts)"]
        CHAT["Chat Interface<br/>(Full-screen Mode)"]
    end

    subgraph OUTPUT["📄 OUTPUT & REPORTING"]
        direction TB
        CHARTS["Interactive Charts<br/>(Canvas Rendering)"]
        PDF["PDF Export<br/>(Health Reports)"]
        CSVOUT["CSV Export<br/>(Timestamped Data)"]
        REPORT["Diagnostic Report<br/>(Condition Cards)"]
        TIMESLIP["Drag Timeslip<br/>(Performance Card)"]
    end

    %% User connections
    OBD --> ELM
    OBD --> PEAK
    PEAK --> PCAN
    CSV --> PARSER

    %% Hardware to protocol
    ELM --> OBDP
    PCAN --> OBDP
    PCAN --> UDS
    PCAN --> RAW

    %% Protocol to transport
    OBDP --> OBDC
    UDS --> UDST
    RAW --> ISPY

    %% Transport to data
    OBDC --> PID_DB
    UDST --> UDS_DB
    UDST --> MOD_DB
    OBDC --> VIN_DB
    OBDC --> DTC_DB

    %% Data feeds tools
    PID_DB --> LOGGER
    UDS_DB --> CODING
    UDS_DB --> CANAM
    UDS_DB --> PROCS
    MOD_DB --> SCAN
    MOD_DB --> ISPY
    DTC_DB --> DTC_RDR
    VIN_DB --> LOGGER

    %% Tools feed analysis
    LOGGER --> PARSER
    PARSER --> DIAG
    DIAG --> REASON
    REASON --> HEALTH
    PARSER --> DRAG

    %% Analysis feeds output
    DIAG --> CHARTS
    DIAG --> REPORT
    HEALTH --> PDF
    HEALTH --> REPORT
    DRAG --> TIMESLIP
    LOGGER --> CSVOUT

    %% Erika connections (feeds from everything)
    KB --> LLM
    PID_DB -.->|"PID knowledge"| KB
    UDS_DB -.->|"UDS expertise"| KB
    MOD_DB -.->|"Module maps"| KB
    DTC_DB -.->|"Code definitions"| KB
    DIAG -.->|"Fault context"| LLM
    HEALTH -.->|"Health scores"| LLM
    LLM --> CHAT

    %% Erika assists tools
    CHAT -.->|"Guides user"| CODING
    CHAT -.->|"Explains faults"| REPORT
    CHAT -.->|"Decodes frames"| ISPY

    %% Styling
    classDef red fill:#dc2626,stroke:#dc2626,color:#fff
    classDef dark fill:#1e293b,stroke:#334155,color:#e2e8f0
    classDef green fill:#059669,stroke:#059669,color:#fff
    classDef blue fill:#2563eb,stroke:#2563eb,color:#fff
    classDef yellow fill:#d97706,stroke:#d97706,color:#fff
    classDef purple fill:#7c3aed,stroke:#7c3aed,color:#fff

    class OBD,CSV,PEAK red
    class ELM,PCAN,OBDP,UDS,RAW dark
    class OBDC,UDST blue
    class STD,GM_EXT,FORD_EXT,BMW_EXT,PS_EXT dark
    class DID_TBL,SEC_ACC,ROUTINE,IO_CTL,NRC dark
    class FORD_MOD,RAM_MOD,GM_MOD dark
    class VIN_DB,DTC_DB dark
    class PARSER,DIAG,REASON,HEALTH,DRAG purple
    class LOGGER,ISPY,CODING,CANAM,PROCS,DTC_RDR,SCAN green
    class LLM,KB,CHAT yellow
    class CHARTS,PDF,CSVOUT,REPORT,TIMESLIP blue
