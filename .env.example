# Copy to ".env" and fill in values. Never commit .env.

# ── LLM (Knox, Laura, IntelliSpy, Pitch, voice, etc.) ─────────────────────
# Manus-hosted apps inject BUILT_IN_FORGE_* on their servers; those keys are NOT exportable.
# For local dev, use your own OpenAI-compatible API:
#
# OpenAI:
#   BUILT_IN_FORGE_API_URL=https://api.openai.com
#   BUILT_IN_FORGE_API_KEY=sk-...
#   LLM_MODEL=gpt-4o-mini
#
# Other OpenAI-compatible hosts (set LLM_OPENAI_COMPAT=1 if the URL is not auto-detected):
#   LLM_OPENAI_COMPAT=1
#   BUILT_IN_FORGE_API_URL=https://your-proxy.example.com
#   BUILT_IN_FORGE_API_KEY=...
#   LLM_MODEL=your-model-id

BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
# When Forge vars are empty: development uses ./.data/object-storage (see server/storage.ts).
# Production requires Forge or an explicit disk directory:
# LOCAL_OBJECT_STORAGE_DIR=/var/lib/vop-object-storage
# LLM_MODEL=
# LLM_OPENAI_COMPAT=1

# ── Manus WebDev (same shape as hosted Manus injects — local copy/paste from dashboard) ──
# Sign-in uses portal.manus.im + api.manus.im by default if you omit the two URL lines below.
# VITE_APP_ID=
# JWT_SECRET=
# OAUTH_SERVER_URL=https://api.manus.im
# VITE_OAUTH_PORTAL_URL=https://portal.manus.im
# OWNER_OPEN_ID=
#
# Forge / LLM — hosted apps use platform keys; locally use OpenAI or Manus forge key:
# BUILT_IN_FORGE_API_URL=https://forge.manus.im
# BUILT_IN_FORGE_API_KEY=
# Client-side Forge proxy (maps, etc.):
# VITE_FRONTEND_FORGE_API_URL=https://forge.manus.im
# VITE_FRONTEND_FORGE_API_KEY=
#
# Tune Deploy: require OAuth for /api/tune-deploy/analyze even in development (default: off)
# TUNE_DEPLOY_REQUIRE_AUTH_FOR_ANALYZE=1
#
# ── Optional: owner alerts (same payload as Manus SendNotification) ─────────
# Slack / Zapier / internal HTTPS endpoint — JSON body: { "text", "title", "content" }
# OWNER_ALERT_WEBHOOK_URL=
# OWNER_ALERT_WEBHOOK_SECRET=
#
# Email to support@ppei.com (or OWNER_ALERT_EMAIL_TO) via Resend — verify your domain at resend.com
# RESEND_API_KEY=re_...
# OWNER_ALERT_EMAIL_FROM=V-OP Alerts <alerts@your-verified-domain.com>
# OWNER_ALERT_EMAIL_TO=support@ppei.com

# ── Optional: DB ───────────────────────────────────────────────────────────
# DATABASE_URL=
