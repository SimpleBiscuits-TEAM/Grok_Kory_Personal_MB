# Copy to ".env" and fill in values. Never commit .env.

# ── LLM (Knox, Laura, IntelliSpy, Pitch, voice, etc.) ─────────────────────
# Manus-hosted apps inject BUILT_IN_FORGE_* on their servers; those keys are NOT exportable.
# For local dev, use your own OpenAI-compatible API:
#
# OpenAI:
#   BUILT_IN_FORGE_API_URL=https://api.openai.com
#   BUILT_IN_FORGE_API_KEY=sk-...
#   LLM_MODEL=gpt-4o-mini
#
# Other OpenAI-compatible hosts (set LLM_OPENAI_COMPAT=1 if the URL is not auto-detected):
#   LLM_OPENAI_COMPAT=1
#   BUILT_IN_FORGE_API_URL=https://your-proxy.example.com
#   BUILT_IN_FORGE_API_KEY=...
#   LLM_MODEL=your-model-id

BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
# LLM_MODEL=
# LLM_OPENAI_COMPAT=1

# ── Optional: DB, OAuth, maps (see client Map.tsx / GeofencePanel) ─────────
# DATABASE_URL=
# JWT_SECRET=
# VITE_FRONTEND_FORGE_API_URL=
# VITE_FRONTEND_FORGE_API_KEY=
